# MongoDB connection string (local, LAN, or Atlas)
MONGODB_URI=your_mongodb_connection_string

# Must match the URL staff use in the browser — use the server LAN IP + port (e.g. http://192.168.1.50:3000)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional: explicit public origin if you need absolute URLs in server code (otherwise use NEXTAUTH_URL)
# NEXT_PUBLIC_APP_URL=http://192.168.1.50:3000

# Optional: shown on printed letterhead (e.g. consultation receipt footer)
# NEXT_PUBLIC_HOSPITAL_EMAIL=doctorsmedicalcenter24@gmail.com

# Optional: Next.js listens on this port (default 3000). Port 80 on Windows may require admin rights.
# PORT=3000

# Optional: auto-delete old logs (default 90 days)
# LOG_RETENTION_DAYS=90
